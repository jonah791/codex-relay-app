{
  "name": "codex-relay-app",
  "version": "1.0.4",
  "description": "Codex CLI relay with system tray - model mapping + Responses API translation",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "jonah791",
  "build": {
    "appId": "com.codexrelay.app",
    "productName": "Codex Relay",
    "files": [
      "main.js", "relay.js", "preload.js", "settings.html",
      "providers.json", "config.default.json", "build/**"
    ],
    "win": { "target": "portable", "icon": "build/icon.ico" },
    "portable": { "artifactName": "Codex-Relay-v${version}.exe" }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  }
}
